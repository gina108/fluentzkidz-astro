---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";

const values = [
  {
    title: "Interactive instruction",
    text: "Lessons are built to keep children participating instead of passively watching."
  },
  {
    title: "Communication first",
    text: "Students practice using Spanish in real situations so confidence grows with skill."
  },
  {
    title: "Low-risk start",
    text: "Families can try the first two classes free before committing to a weekly plan."
  }
];

const principles = [
  {
    title: "Comprehensible input",
    text: "Children learn best when Spanish is understandable, repeated in context, and tied to meaning."
  },
  {
    title: "Low-stress participation",
    text: "The class environment should invite speaking, not punish mistakes or create pressure."
  },
  {
    title: "Real consistency",
    text: "Steady short sessions often work better for families than occasional long lessons."
  }
];
---

<BaseLayout
  title="About | Fluentz Kidz"
  description="Learn about Fluentz Kidz and its approach to interactive Spanish classes for children."
  path="/about"
>
  <SiteHeader currentPath="/about" />
  <main>
    <section class="page-hero">
      <div class="container hero-grid">
        <div>
          <span class="pill">About Fluentz Kidz</span>
          <h1 class="section-title">Spanish classes designed to help kids actually use the language.</h1>
        </div>
        <p class="section-copy">
          Fluentz Kidz is built around the idea that language learning should feel active,
          practical, and encouraging. The original WordPress page focused on immersive instruction,
          confidence in communication, and opening new cultural opportunities. This rebuild keeps
          that message but presents it more clearly.
        </p>
      </div>
    </section>

    <section class="story">
      <div class="container story-grid">
        <article class="card story-card">
          <h2>What the program emphasizes</h2>
          <p>
            Classes are structured to move beyond grammar drills and isolated vocabulary. Children
            take part in interactive lessons, conversational practice, role-playing, and guided
            repetition that makes Spanish feel usable from the start.
          </p>
          <p>
            Whether a student is new to Spanish or refining existing skills, the goal is the same:
            build enough comfort to speak, respond, and participate with confidence.
          </p>
        </article>
        <aside class="card quote-card">
          <p>
            “Language is best taught when it is being used to transmit messages, not when it is
            explicitly taught for conscious learning.”
          </p>
          <span>Stephen D. Krashen</span>
        </aside>
      </div>
    </section>

    <section class="values">
      <div class="container cards">
        {values.map((value) => (
          <article class="card value-card">
            <h3>{value.title}</h3>
            <p>{value.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="principles">
      <div class="container principles-grid">
        <div>
          <span class="pill">Teaching principles</span>
          <h2 class="section-title">The program is built for retention, not just exposure.</h2>
        </div>
        <div class="principles-list">
          {principles.map((item) => (
            <article class="card principle-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="cta">
      <div class="container card cta-card">
        <div>
          <span class="pill">Next step</span>
          <h2>Book the first two classes free.</h2>
          <p class="section-copy">
            Families can reach out for scheduling and questions before choosing a weekly plan.
          </p>
        </div>
        <a class="button primary" href="/contact">Go to Contact</a>
      </div>
    </section>
  </main>
  <SiteFooter />

  <style>
    .page-hero,
    .story,
    .values,
    .principles,
    .cta {
      padding: 4rem 0;
    }

    .hero-grid,
    .story-grid,
    .cta-card {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2rem;
      align-items: start;
    }

    .story-card,
    .quote-card,
    .value-card,
    .principle-card,
    .cta-card {
      padding: 1.5rem;
    }

    .story-card h2,
    .cta-card h2 {
      margin-top: 0;
      font-family: "Fredoka", sans-serif;
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1;
    }

    .story-card p,
    .value-card p,
    .quote-card span {
      color: var(--muted);
      line-height: 1.8;
    }

    .quote-card p {
      margin-top: 0;
      font-family: "Fredoka", sans-serif;
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      line-height: 1.2;
    }

    .cards,
    .principles-list {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.25rem;
    }

    .value-card h3 {
      margin-top: 0;
      margin-bottom: 0.75rem;
      font-size: 1.2rem;
    }

    .principles-grid {
      display: grid;
      gap: 2rem;
    }

    .principle-card h3 {
      margin-top: 0;
      margin-bottom: 0.75rem;
    }

    .principle-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.8;
    }

    .cta-card {
      align-items: center;
    }

    @media (max-width: 900px) {
      .hero-grid,
      .story-grid,
      .cta-card,
      .cards,
      .principles-list {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
