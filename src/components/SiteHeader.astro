---
interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const navItems = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/pricing", label: "Pricing" },
  { href: "/practice", label: "Practice" },
  { href: "/contact", label: "Contact" }
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/">
      <img class="brand-logo" src="/logo1x256.png" alt="Fluentz Kidz logo" />
      <span class="brand-text">Fluentz Kidz</span>
    </a>
    <nav class="nav">
      {navItems.map((item) => (
        <a class={item.href === currentPath ? "active" : undefined} href={item.href}>{item.label}</a>
      ))}
    </nav>
    <a class="button secondary header-cta" href="/contact">Book Free Classes</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    padding: 1rem 0;
    backdrop-filter: blur(18px);
    background: rgba(13, 15, 31, 0.72);
    border-bottom: 1px solid rgba(112, 49, 146, 0.24);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    font-weight: 800;
  }

  .brand-logo {
    width: 3rem;
    height: 3rem;
    object-fit: contain;
    border-radius: 0.95rem;
    box-shadow: 0 12px 26px rgba(112, 49, 146, 0.26);
  }

  .brand-text {
    font-family: "Fredoka", sans-serif;
    font-size: 1.2rem;
    letter-spacing: 0.02em;
  }

  .nav {
    display: inline-flex;
    gap: 1.3rem;
    color: var(--muted);
    font-weight: 800;
  }

  .nav a.active {
    color: var(--ink);
  }

  .header-cta {
    min-height: 2.9rem;
  }

  @media (max-width: 720px) {
    .site-header {
      position: static;
    }

    .header-inner {
      flex-wrap: wrap;
    }

    .nav {
      order: 3;
      width: 100%;
      justify-content: space-between;
    }

    .header-cta {
      display: none;
    }
  }
</style>
